function deploy-staging () {
	./vendor/bin/envoy run deploy --target=staging --branch=${1}
}

function sail () {
	./vendor/bin/sail $@
}


function sl () {
	streamlabs-dev $@
}

function sl-setup () {
	sl-loopthrough "setup" $@
}

function  sl-start-fast () {
	sl-loopthrough "start-fast" $@
}

function sl-start () {
	sl-loopthrough "start" $@
}

function sl-stop () {
	sl-loopthrough "stop" $@
}

function sl-build () {
	sl-loopthrough "build" $@
}

function sl-loopthrough () {
	sites=(${@:2})
	for site in "${sites[@]}"; do
		if [ ${site} = "core" ]
		then
			sl ${1} streamlabs.com
		elif [ ${site} = "ultra" ]
		then
			if [ ${1} = "stop" ]
			then
				ultra && make stop
			else
				ultra && make start
			fi
		elif [ ${site} = "kraken" ]
		then
			if [ ${1} = "stop" ]
			then
				sl-stop core && kraken && make stop
			else
				sl-start-fast core && kraken && make start
			fi
		else
			sl ${1} ${site}
		fi

	done
}
